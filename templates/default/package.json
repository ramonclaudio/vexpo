{
  "name": "vexpo",
  "version": "0.1.11",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "start": "expo start --dev-client --clear",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:logs": "convex logs",
    "convex:logs:prod": "convex logs --prod",
    "convex:env": "convex env list",
    "convex:env:prod": "convex env list --prod",
    "convex:insights": "convex insights",
    "convex:insights:prod": "convex insights --prod",
    "convex:dashboard": "convex dashboard",
    "convex:codegen": "convex codegen",
    "ios": "node scripts/_run.mjs scripts/clean.ts --metro && expo prebuild --clean --platform ios && expo run:ios --no-build-cache",
    "ios:dev": "expo run:ios",
    "ios:device": "node scripts/_run.mjs scripts/clean.ts --metro && expo prebuild --clean --platform ios && expo run:ios --device --no-build-cache",
    "prebuild": "expo prebuild --clean --platform ios",
    "eas:dev": "npx eas-cli build -p ios --profile development:simulator",
    "eas:dev:device": "npx eas-cli build -p ios --profile development:device",
    "eas:tf": "npx eas-cli build -p ios --profile production --auto-submit-with-profile testflight",
    "eas:prod": "npx eas-cli build -p ios --profile production",
    "metadata:lint": "npx eas-cli metadata:lint",
    "metadata:push": "npx eas-cli metadata:lint && npx eas-cli metadata:push",
    "metadata:pull": "npx eas-cli metadata:pull",
    "env:pull": "npx eas-cli env:pull --environment development",
    "env:pull:prod": "npx eas-cli env:pull --environment production",
    "clean": "node scripts/_run.mjs scripts/clean.ts",
    "clean:metro": "node scripts/_run.mjs scripts/clean.ts --metro",
    "clean:state": "node scripts/_run.mjs scripts/clean.ts --state",
    "typecheck": "tsc --noEmit",
    "fp": "npx @expo/fingerprint fingerprint:generate",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "upgrade": "npx expo install expo@next && npx expo install --fix",
    "upgrade:stable": "npx expo install expo@latest && npx expo install --fix",
    "updates:gen-cert": "node scripts/gen-update-cert.mjs"
  },
  "dependencies": {
    "@better-auth/expo": "1.6.22",
    "@convex-dev/better-auth": "0.12.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/resend": "^0.2.5",
    "@expo/ui": "~57.0.1",
    "better-auth": "1.6.22",
    "convex": "~1.42.0",
    "convex-helpers": "^0.1.120",
    "expo": "~57.0.1",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-asset": "~57.0.2",
    "expo-blur": "~57.0.0",
    "expo-build-properties": "~57.0.2",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-insights": "~57.0.1",
    "expo-linking": "~57.0.1",
    "expo-local-authentication": "~57.0.0",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.2",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-task-manager": "~57.0.1",
    "expo-updates": "~57.0.4",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ramonclaudio/vexpo": "^0.1.8",
    "@types/node": "^22",
    "@types/react": "~19.2.16",
    "convex-test": "^0.0.54",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "react-dom": "19.2.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "listUnknownPackages": true,
        "exclude": [
          "expo-modules-jsi"
        ]
      }
    }
  }
}

{
  "name": "@ramonclaudio/vexpo",
  "version": "0.1.6",
  "description": "Operational CLI for vexpo projects: setup orchestration, drift detection, env sync, Apple JWT signing, ASC API integration.",
  "keywords": [
    "apple-sign-in",
    "better-auth",
    "cli",
    "convex",
    "eas",
    "expo",
    "resend",
    "setup",
    "vexpo"
  ],
  "homepage": "https://github.com/ramonclaudio/vexpo/tree/main/packages/vexpo#readme",
  "bugs": {
    "url": "https://github.com/ramonclaudio/vexpo/issues"
  },
  "license": "MIT",
  "author": "Ramon Claudio <hello@ramonclaudio.com> (https://github.com/ramonclaudio)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramonclaudio/vexpo.git",
    "directory": "packages/vexpo"
  },
  "bin": {
    "vexpo": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && __tests__/e2e/run.sh",
    "test:e2e:api": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.10"
  }
}
